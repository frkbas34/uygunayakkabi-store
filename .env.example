# ─────────────────────────────────────────────────────────────
# Uygunayakkabi — Environment Variables Template
# Copy to .env.local for local development.
# All production values are set in Vercel Dashboard → Settings → Env Vars.
# ─────────────────────────────────────────────────────────────

# ── Core: Database ────────────────────────────────────────────
# PostgreSQL - Neon.tech
# NOTE: do NOT append ?sslmode=require — SSL is handled via payload.config.ts pool options
DATABASE_URI=postgresql://USER:PASSWORD@HOST/DATABASE

# ── Core: Payload CMS ─────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-secret-here-min-32-chars

# ── Core: Next.js ─────────────────────────────────────────────
# Public base URL — used for absolute media URLs in channel dispatch payloads
# Production: https://uygunayakkabi.com
# Development: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=905331524843

# ── Media Storage: Vercel Blob ────────────────────────────────
# Required for production media uploads via @payloadcms/storage-vercel-blob
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── Phase 2: Automation Pipeline ─────────────────────────────

# Shared secret for POST /api/automation/products
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTOMATION_SECRET=your-automation-secret-here

# n8n intake webhook URL (OpenClaw → n8n → Payload)
# n8n workflow: mentix-intake at flow.uygunayakkabi.com
N8N_INTAKE_WEBHOOK=https://flow.uygunayakkabi.com/webhook/mentix-intake

# ── Phase 2: Channel Dispatch Webhooks ───────────────────────
# Set after importing n8n stub workflows and activating them.
# Leave empty to run in scaffold mode (dispatch logged but not sent).
# See: n8n-workflows/CHANNEL_DISPATCH_CONTRACT.md for full setup guide.
#
# After importing n8n-workflows/stubs/channel-instagram.json to n8n:
N8N_CHANNEL_INSTAGRAM_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-instagram
#
# After importing n8n-workflows/stubs/channel-shopier.json to n8n:
N8N_CHANNEL_SHOPIER_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-shopier
#
# After importing n8n-workflows/stubs/channel-dolap.json to n8n:
N8N_CHANNEL_DOLAP_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-dolap
#
# Social media channels (import stubs from n8n-workflows/stubs/ first):
N8N_CHANNEL_X_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-x
N8N_CHANNEL_FACEBOOK_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-facebook
N8N_CHANNEL_LINKEDIN_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-linkedin
N8N_CHANNEL_THREADS_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-threads

# ── Phase 2 (future): Telegram Bot ───────────────────────────
# Only needed if polling mode is used (not required for webhook/OpenClaw flow)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ── Phase 2B: Meta OAuth (Instagram + Facebook + Threads) ────
# Shared Meta App — same App ID/Secret covers Instagram, Facebook Page, and Threads.
# Callback URLs to register in Meta Developer Portal:
#   Instagram:  https://uygunayakkabi.com/api/auth/instagram/callback
#
# Get both values from: developers.facebook.com → Your App → Settings → Basic
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret

# ── Phase 2B: X (Twitter) OAuth ──────────────────────────────
# Get from: developer.x.com → Your App → Keys and Tokens
# Callback URL: https://uygunayakkabi.com/api/auth/x/callback
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# ── Phase 2B: LinkedIn OAuth ─────────────────────────────────
# Get from: linkedin.com/developers → Your App → Auth
# Callback URL: https://uygunayakkabi.com/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Numeric ID of your LinkedIn Company Page (for organization posting)
# Find via: linkedin.com/company/{slug} → Admin View → Settings → Page ID
LINKEDIN_ORGANIZATION_ID=

# ── Phase 3 (future): AI / Image Generation ──────────────────
OPENAI_API_KEY=your-openai-api-key
