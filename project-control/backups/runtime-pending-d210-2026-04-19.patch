+    return imageBuffer
+  }
+
+  const meanLum = lumSum / productPixelCount
+
+  // ── Determine correction needed ──
+  const TARGET_LOW  = 100  // below this = too dark
+  const TARGET_HIGH = 170  // above this = too bright
+  const TARGET_MID  = 135  // ideal target when correcting
