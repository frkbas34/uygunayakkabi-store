# ─────────────────────────────────────────────────────────────
# Uygunayakkabi — Environment Variables Template
# Copy to .env.local for local development.
# All production values are set in Vercel Dashboard → Settings → Env Vars.
# ─────────────────────────────────────────────────────────────

# ── Core: Database ────────────────────────────────────────────
# PostgreSQL - Neon.tech
# NOTE: do NOT append ?sslmode=require — SSL is handled via payload.config.ts pool options
DATABASE_URI=postgresql://USER:PASSWORD@HOST/DATABASE

# ── Core: Payload CMS ─────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-secret-here-min-32-chars

# ── Core: Next.js ─────────────────────────────────────────────
# Public base URL — used for absolute media URLs in channel dispatch payloads
# Production: https://uygunayakkabi.com
# Development: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=905331524843

# ── Media Storage: Vercel Blob ────────────────────────────────
# Required for production media uploads via @payloadcms/storage-vercel-blob
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── Phase 2: Automation Pipeline ─────────────────────────────

# Shared secret for POST /api/automation/products
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTOMATION_SECRET=your-automation-secret-here

# n8n intake webhook URL (OpenClaw → n8n → Payload)
# n8n workflow: mentix-intake at flow.uygunayakkabi.com
N8N_INTAKE_WEBHOOK=https://flow.uygunayakkabi.com/webhook/mentix-intake

# ── Phase 2: Channel Dispatch Webhooks ───────────────────────
# Set after importing n8n stub workflows and activating them.
# Leave empty to run in scaffold mode (dispatch logged but not sent).
# See: n8n-workflows/CHANNEL_DISPATCH_CONTRACT.md for full setup guide.
#
# After importing n8n-workflows/stubs/channel-instagram.json to n8n:
N8N_CHANNEL_INSTAGRAM_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-instagram
#
# After importing n8n-workflows/stubs/channel-shopier.json to n8n:
N8N_CHANNEL_SHOPIER_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-shopier
#
# After importing n8n-workflows/stubs/channel-dolap.json to n8n:
N8N_CHANNEL_DOLAP_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-dolap
#
# Social media channels (import stubs from n8n-workflows/stubs/ first):
N8N_CHANNEL_X_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-x
N8N_CHANNEL_FACEBOOK_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-facebook
N8N_CHANNEL_LINKEDIN_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-linkedin
N8N_CHANNEL_THREADS_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-threads

# ── Phase 2 (future): Telegram Bot ───────────────────────────
# Only needed if polling mode is used (not required for webhook/OpenClaw flow)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ── Phase 2B: Meta OAuth (Instagram + Facebook + Threads) ────
# Shared Meta App — same App ID/Secret covers Instagram, Facebook Page, and Threads.
# Callback URLs to register in Meta Developer Portal:
#   Instagram:  https://uygunayakkabi.com/api/auth/instagram/callback
#
# Get both values from: developers.facebook.com → Your App → Settings → Basic
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret

# ── Step 17: n8n REST API Access ─────────────────────────────
# Required for the Instagram OAuth callback to write INSTAGRAM_ACCESS_TOKEN
# and INSTAGRAM_USER_ID directly into n8n Variables after token exchange.
# Generate at: flow.uygunayakkabi.com → Settings → API → Create an API key
N8N_API_KEY=your-n8n-api-key
# Base URL of your n8n instance. Default used in code: https://flow.uygunayakkabi.com
# Only set this if your n8n runs on a different host.
N8N_BASE_URL=https://flow.uygunayakkabi.com

# ── Phase 2B: X (Twitter) OAuth ──────────────────────────────
# Get from: developer.x.com → Your App → Keys and Tokens
# Callback URL: https://uygunayakkabi.com/api/auth/x/callback
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# ── Phase 2B: LinkedIn OAuth ─────────────────────────────────
# Get from: linkedin.com/developers → Your App → Auth
# Callback URL: https://uygunayakkabi.com/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Numeric ID of your LinkedIn Company Page (for organization posting)
# Find via: linkedin.com/company/{slug} → Admin View → Settings → Page ID
LINKEDIN_ORGANIZATION_ID=

# ── Step 20: Shopier API Integration ──────────────────────────
# Personal Access Token — get from Shopier: Hesap Yönetimi → Kişisel Erişim Anahtarı
# Requires 2FA enabled on your Shopier account.
# CRITICAL: Never expose this client-side or in Telegram messages.
SHOPIER_PAT=your-shopier-personal-access-token

# Shopier webhook signing token — returned when creating webhook subscription
# (only shown once on initial create response, never again).
# Used to verify incoming webhook events via HMAC-SHA256.
SHOPIER_WEBHOOK_TOKEN=your-shopier-webhook-token

# Telegram chat ID for Shopier order/refund notifications.
# Get from: send a message to your bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
SHOPIER_NOTIFY_CHAT_ID=your-telegram-chat-id

# ── Step 20: Payload Jobs Queue ────────────────────────────────
# Secret token used to secure the GET /api/payload-jobs/run endpoint.
# Vercel Cron automatically sends: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
# Leave UNSET for local development (endpoint is open locally).
# Set in Vercel Dashboard → Settings → Environment Variables (Production only).
CRON_SECRET=

# ── Step 25: AI / Image Generation ───────────────────────────
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Step 25 v14: Gemini Pro image generation model
# Used when operator sends #gorsel #geminipro
# Set explicitly to lock the A/B benchmark model
GEMINI_IMAGE_GEN_MODEL=gemini-3-pro-image-preview

# ── Step 27: Claid.ai Image Enhancement ─────────────────────────────────────
# Claid.ai product photo enhancement API — https://claid.ai
# Triggered via Telegram: #claid {productId} → mode selection keyboard
# Endpoint: POST /v1/image/edit/upload (multipart/form-data)
#
# Three modes available:
#   cleanup  — white background + smart upscale + sharpening (marketplace-ready)
#   studio   — premium contrast/HDR, no background change
#   creative — editorial grey background + mild enhancement
#
# Get your API key from: https://claid.ai/dashboard → API Keys
# CRITICAL: Never expose this key client-side or log it. Keep in env only.
CLAID_API_KEY=your-claid-api-key

# Claid API base URL (optional — default: https://api.claid.ai/v1)
# Only set if using a different Claid endpoint or proxy.
CLAID_BASE_URL=https://api.claid.ai/v1

# Claid request timeout in milliseconds (optional — default: 60000)
# Increase if processing large images or getting timeout errors.
CLAID_TIMEOUT_MS=60000

# ── Step 26: Luma AI Image Generation ────────────────────────────────────────
# Luma Dream Machine API key — get from: https://lumalabs.ai/dream-machine/api
# Required to use #luma command in Telegram
LUMA_API_KEY=your-luma-api-key

# Luma generation models (optional — defaults shown below)
# photon-flash-1 = fast, lower cost (default for all #luma generations)
# photon-1       = higher quality (used when operator clicks HQ rerun button)
LUMA_MODEL_DEFAULT=photon-flash-1
LUMA_MODEL_HQ=photon-1
