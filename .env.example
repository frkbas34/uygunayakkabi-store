# ─────────────────────────────────────────────────────────────
# Uygunayakkabi — Environment Variables Template
# Copy to .env.local for local development.
# All production values are set in Vercel Dashboard → Settings → Env Vars.
# Last updated: 2026-04-04 (D-115 Env Truth Pass)
# ─────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
# CRITICAL — App will not start without these
# ══════════════════════════════════════════════════════════════

# ── Core: Database ────────────────────────────────────────────
# PostgreSQL - Neon.tech
# NOTE: do NOT append ?sslmode=require — SSL is handled via payload.config.ts pool options
DATABASE_URI=postgresql://USER:PASSWORD@HOST/DATABASE

# ── Core: Payload CMS ─────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-secret-here-min-32-chars

# ── Core: Next.js ─────────────────────────────────────────────
# Public base URL — used for absolute media URLs in channel dispatch payloads
# Production: https://uygunayakkabi.com
# Development: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════
# REQUIRED FOR CORE OPERATOR FLOW
# ══════════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────────
# Core operator interface — intake, commands, notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
# Chat ID for stock alerts, system notifications, operator messages
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Media Storage: Vercel Blob ────────────────────────────────
# Required for production media uploads via @payloadcms/storage-vercel-blob
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ══════════════════════════════════════════════════════════════
# REQUIRED FOR AI / CONTENT GENERATION
# ══════════════════════════════════════════════════════════════

# ── Gemini API (Geobot content gen + image gen) ──────────────
GEMINI_API_KEY=your-gemini-api-key
# Image gen model override (default: gemini-2.5-flash-image)
# Alternatives: gemini-3-pro-image-preview, gemini-3.1-flash-image-preview
# WARNING: gemini-2.0-flash-preview-image-generation is DEPRECATED (returns 404)
# GEMINI_IMAGE_GEN_MODEL=gemini-2.5-flash-image
# Vision model override (default: gemini-2.0-flash)
# GEMINI_VISION_MODEL=gemini-2.0-flash

# ── OpenAI (image editing — currently disabled in operator flow) ──
OPENAI_API_KEY=your-openai-api-key
# Image model override (default: gpt-image-1)
# OPENAI_IMAGE_MODEL=gpt-image-1

# ── Anthropic Claude (Telegram NLP) ──────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Claid.ai (product photo enhancement) ─────────────────────
# Triggered via Telegram: #claid {productId} → mode keyboard
# 3 modes: cleanup (white bg), studio (HDR), creative (editorial)
CLAID_API_KEY=your-claid-api-key
# Optional overrides (defaults shown):
# CLAID_BASE_URL=https://api.claid.ai/v1
# CLAID_TIMEOUT_MS=60000

# ── Luma AI (image/video gen — currently disabled in operator flow) ──
LUMA_API_KEY=your-luma-api-key
# Model overrides (defaults: photon-flash-1 / photon-1):
# LUMA_MODEL_DEFAULT=photon-flash-1
# LUMA_MODEL_HQ=photon-1

# ══════════════════════════════════════════════════════════════
# REQUIRED FOR COMMERCE / SHOPIER
# ══════════════════════════════════════════════════════════════

# ── Shopier API ───────────────────────────────────────────────
# Personal Access Token — Hesap Yönetimi → Kişisel Erişim Anahtarı (requires 2FA)
SHOPIER_PAT=your-shopier-personal-access-token
# Webhook signing token — HMAC-SHA256 verification (shown once on webhook create)
SHOPIER_WEBHOOK_TOKEN=your-shopier-webhook-token
# Telegram chat ID for order/refund notifications (optional)
# SHOPIER_NOTIFY_CHAT_ID=your-chat-id

# ══════════════════════════════════════════════════════════════
# REQUIRED FOR SOCIAL PUBLISHING
# ══════════════════════════════════════════════════════════════

# ── Meta OAuth (Instagram + Facebook + Threads) ──────────────
# Same Meta App covers all three. Get from: developers.facebook.com → App → Settings → Basic
# Callback: https://uygunayakkabi.com/api/auth/instagram/callback
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret
# Optional fallback IDs (bypass OAuth for specific page/user):
# INSTAGRAM_PAGE_ID=your-facebook-page-id
# INSTAGRAM_USER_ID=your-instagram-user-id

# ── X (Twitter) OAuth ────────────────────────────────────────
# Get from: developer.x.com → App → Keys and Tokens
# Callback: https://uygunayakkabi.com/api/auth/x/callback
# NOTE: X posting not yet implemented — OAuth scaffold only
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# ── Channel Dispatch Webhooks (n8n) ──────────────────────────
# Set after importing n8n stub workflows. Leave empty for scaffold mode.
# See: n8n-workflows/CHANNEL_DISPATCH_CONTRACT.md
N8N_CHANNEL_INSTAGRAM_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-instagram
N8N_CHANNEL_SHOPIER_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-shopier
N8N_CHANNEL_DOLAP_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-dolap
N8N_CHANNEL_X_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-x
N8N_CHANNEL_FACEBOOK_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-facebook
N8N_CHANNEL_THREADS_WEBHOOK=https://flow.uygunayakkabi.com/webhook/channel-threads

# ══════════════════════════════════════════════════════════════
# OPTIONAL / INFRASTRUCTURE
# ══════════════════════════════════════════════════════════════

# ── Automation Pipeline ──────────────────────────────────────
# Auth secret for POST /api/automation/products (OpenClaw/n8n intake)
AUTOMATION_SECRET=your-automation-secret-here

# ── API Key Generation (one-time setup) ──────────────────────
# Secret for POST /api/generate-api-key endpoint
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GENERATE_API_KEY_SECRET=your-generate-api-key-secret

# ── Jobs Queue (Vercel Cron) ─────────────────────────────────
# Bearer token for GET /api/payload-jobs/run
# Generate: openssl rand -hex 32
# Leave UNSET for local dev (endpoint open locally)
CRON_SECRET=

# ── WhatsApp (storefront display only) ───────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=905331524843

# ── Product Intelligence Bot — reverse image search ──────────
# The PI Bot (#geohazirla / #urunzeka / #seoara / #productintel) runs
# reverse image search on the product's original + best supporting image
# (max 2) and includes the results in the Telegram report.
#
# Provider selection (REVERSE_SEARCH_PROVIDER):
#   - "dataforseo"  → force DataForSEO (requires LOGIN+PASSWORD)
#   - "serpapi"     → force SerpAPI (requires SERPAPI_API_KEY)
#   - "auto" (default) → prefer DataForSEO if creds exist, else SerpAPI
# If nothing is configured the pipeline still works — the report is
# honestly flagged "Online arama kullanılamıyor" and match confidence is
# downgraded to `visual_only_no_external_search`.
REVERSE_SEARCH_PROVIDER=dataforseo

# DataForSEO — pay-as-you-go, no monthly subscription. Preferred for the
# low-volume PI use case (~300 searches/month). Google reverse-image
# search via their "Google Lens" SERP endpoint.
# Sign-up: https://dataforseo.com/ → Profile → API Dashboard
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_LOCATION_NAME=Turkey
DATAFORSEO_LANGUAGE_NAME=Turkish
DATAFORSEO_DEPTH=10
DATAFORSEO_MAX_IMAGES=2
# Poll budget for a single image's async task (ms). Standard queue results
# usually arrive in 5-20s; tighten if Vercel function timeouts become an
# issue, loosen if pending-task warnings appear frequently.
DATAFORSEO_POLL_TIMEOUT_MS=22000
DATAFORSEO_POLL_INTERVAL_MS=2500
DATAFORSEO_INITIAL_DELAY_MS=4000

# SerpAPI (fallback) — monthly quota model. Used only if DataForSEO creds
# are missing or REVERSE_SEARCH_PROVIDER=serpapi.
# Get a key: https://serpapi.com/ (Google Lens engine)
SERPAPI_API_KEY=

# ══════════════════════════════════════════════════════════════
# REMOVED / STALE — No longer referenced in codebase
# ══════════════════════════════════════════════════════════════
# N8N_INTAKE_WEBHOOK — was used for OpenClaw intake, no longer referenced
# N8N_API_KEY — was used for n8n REST API, no longer referenced
# N8N_BASE_URL — was used for n8n instance URL, no longer referenced
