+      bgR += rawPixels[idx]
+      bgG += rawPixels[idx + 1]
+      bgB += rawPixels[idx + 2]
+      bgCount++
+    }
+  }
+
+  const detBg = {
+    r: Math.round(bgR / bgCount),
+    g: Math.round(bgG / bgCount),
+    b: Math.round(bgB / bgCount),
+  }
